# ============================================================
# Tío José María — variables de entorno frontend (Vite)
# ============================================================
# Copia este archivo a .env (local) o configura las vars en Easypanel
# para producción.

# --- Supabase (obligatorio) ---
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# --- Bot IA (opcional) ---
# El asistente virtual flotante de la web pública. Solo aparece cuando
# está en 'true' Y la edge function bot-chat tiene configuradas las
# credenciales de AWS Bedrock y la KB indexada.
# Por defecto desactivado para evitar mostrar el bot con errores.
VITE_BOT_ENABLED=false

# --- Image transformations (opcional, requiere Supabase Pro) ---
# Cuando está en 'true', las imágenes del bucket apartments se sirven
# via /storage/v1/render/image/public/... con webp y srcset 2x.
# En plan Free devuelve 403 — déjalo en 'false' hasta que el proyecto
# Supabase esté en plan Pro.
VITE_SUPABASE_IMAGE_TRANSFORM=false

# --- Motor de reservas externo (opcional, NO usado actualmente) ---
# Si en algún momento se delega el motor a un PMS externo, su URL iframe
# se mete aquí. Por defecto, /reservar usa el motor propio.
# VITE_BOOKING_ENGINE_URL=

# --- Otros ---
STITCH_API_KEY=your-stitch-api-key-here
